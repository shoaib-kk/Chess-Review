# Player Modelling Engine — environment configuration.
# Copy to player_model/.env (used by docker-compose) and adjust.

# --- Auth & CORS ------------------------------------------------------------
# The master API key accepted by every endpoint. MUST match the frontend's
# VITE_PM_API_KEY. Generate a strong value in production.
MASTER_API_KEY=dev-master-key
# Comma-separated allowed browser origins for the engine API (CORS).
FRONTEND_URL=http://localhost:5173

# --- Database / Redis -------------------------------------------------------
PM_DATABASE_URL=sqlite:////data/player_model.db
PM_REDIS_URL=redis://redis:6379/0

# --- Stockfish --------------------------------------------------------------
STOCKFISH_PATH=/usr/games/stockfish
STOCKFISH_DEPTH=18

# --- Chess.com sync (Section 1) ---------------------------------------------
# Chess.com asks API clients to identify themselves; use a real contact in prod.
PM_CHESSCOM_USER_AGENT=PlayerModellingEngine/1.0 (contact: admin@example.com)
# Incremental resync cadence for connected players, in hours (Celery beat).
PM_SYNC_INTERVAL_HOURS=6

# --- FAISS / PCA artifacts --------------------------------------------------
PM_INDEX_DIR=/data/indices
PM_MODELS_DIR=/data/models

# --- Frontend (Vite, build-time) --------------------------------------------
# Set these in the frontend build environment, not here. Shown for reference:
#   VITE_PM_API_BASE_URL=http://127.0.0.1:8000
#   VITE_PM_API_KEY=dev-master-key
