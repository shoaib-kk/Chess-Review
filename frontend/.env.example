# Base URL the frontend uses to reach the backend API. Read at build time (Vite).
#
# - docker-compose: leave as /api — nginx proxies that path to the backend container.
# - Split hosting (e.g. frontend on Vercel, backend on Render/Fly/Railway): set this
#   to the backend's full HTTPS URL, e.g. https://chess-review-api.onrender.com
VITE_API_BASE_URL=/api
