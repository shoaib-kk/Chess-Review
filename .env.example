# Copy to .env and adjust. docker-compose.yml reads these.

# --- PostgreSQL ---
POSTGRES_USER=chess
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=chess

# Connection string used by the backend + Alembic. Inside Docker the host is the
# `db` service. For bare-metal local dev point this at your own Postgres, e.g.
# postgresql+psycopg://chess:chess@localhost:5432/chess
DATABASE_URL=postgresql+psycopg://chess:change-me-in-production@db:5432/chess

# --- Stockfish ---
STOCKFISH_PATH=/usr/games/stockfish
# Engine pool: max concurrent Stockfish processes (each holds one NNUE net in
# RAM). Default 2 — raise on bigger hosts for more analysis throughput, lower to 1
# on memory-constrained instances. The pool reuses warm engines across requests.
STOCKFISH_MAX_ENGINES=2
STOCKFISH_HASH_MB=32
STOCKFISH_THREADS=1
# Wall-clock cap (seconds) on a single engine analyse call; on timeout the engine
# is discarded (so a wedged process can't permanently hold a pool slot).
STOCKFISH_ANALYSE_TIMEOUT_S=60

# --- Redis (shared rate-limit + puzzle-progress state) ---
# Required for correct behaviour across MULTIPLE backend instances. Inside Docker
# the host is the `redis` service. If unset, the app falls back to per-process
# in-memory state (fine for a single instance only). Fails open if Redis is down.
REDIS_URL=redis://redis:6379/0

# --- App environment ---
# APP_ENV defaults to "production" (fail-closed): outside dev, DATABASE_URL must
# be set explicitly rather than falling back to the insecure local default. For
# bare-metal local dev set APP_ENV=dev. Never set APP_ENV=dev in a deployment.
APP_ENV=production
