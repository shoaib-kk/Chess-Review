# Copy to .env and adjust. docker-compose.yml reads these.

# --- PostgreSQL ---
POSTGRES_USER=chess
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=chess

# Connection string used by the backend + Alembic. Inside Docker the host is the
# `db` service. For bare-metal local dev point this at your own Postgres, e.g.
# postgresql+psycopg://chess:chess@localhost:5432/chess
DATABASE_URL=postgresql+psycopg://chess:change-me-in-production@db:5432/chess

# --- Stockfish ---
STOCKFISH_PATH=/usr/games/stockfish
